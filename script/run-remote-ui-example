#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
extension_id="remote-ui-example"
cargo_target_dir="${CARGO_TARGET_DIR:-${repo_root}/target}"
user_data_dir="${repo_root}/target/remote-ui-example-user-data"
config_root="${user_data_dir}/config"
install_root="${user_data_dir}/extensions/installed/${extension_id}"
icon_root="${install_root}/icons"

cd "${repo_root}"

pkill -f '/Applications/Zed.app/Contents/MacOS/zed' || true
pkill -f 'target/debug/zed' || true

cargo build -p zed
cargo build --manifest-path "${repo_root}/extensions/remote-ui-example/Cargo.toml" --target wasm32-wasip2

rm -rf "${user_data_dir}"
mkdir -p "${config_root}" "${icon_root}"

printf '%s\n' \
    '{' \
    '  "audio": {' \
    '    "denoise": false' \
    '  }' \
    '}' > "${config_root}/settings.json"

copy_if_distinct() {
    local source="$1"
    local destination="$2"

    if [[ -e "${destination}" ]] && [[ "$(realpath "${source}")" == "$(realpath "${destination}")" ]]; then
        return 0
    fi

    cp "${source}" "${destination}"
}

copy_if_distinct "${repo_root}/extensions/remote-ui-example/extension.toml" "${install_root}/extension.toml"
copy_if_distinct "${cargo_target_dir}/wasm32-wasip2/debug/remote_ui_example.wasm" "${install_root}/extension.wasm"
copy_if_distinct "${repo_root}/extensions/remote-ui-example/sidecar.js" "${install_root}/sidecar.js"
copy_if_distinct "${repo_root}/extensions/remote-ui-example/icons/ai_open_ai.svg" "${icon_root}/ai_open_ai.svg"

rm -f "${user_data_dir}/extensions/index.json"

RUST_LOG="${RUST_LOG:-extension_host=info,zed::zed::remote_ui_extension=info}" \
    "${cargo_target_dir}/debug/zed" --user-data-dir "${user_data_dir}" "${repo_root}"
